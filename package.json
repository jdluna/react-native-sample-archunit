{
  "name": "analytics-module",
  "version": "1.0.0",
  "description": "React Native Analytics Module with enforced layer architecture",
  "scripts": {
    "test": "jest",
    "arch:check": "jest --testPathPattern='test/arch' --verbose",
    "arch:report": "jest --testPathPattern='test/arch' --verbose --json --outputFile=arch-report.json",
    "arch:html-report": "node scripts/generate-arch-report.js"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "^0.73.11"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "archunit": "^2.1.69",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@contracts/(.*)$": "<rootDir>/src/contracts/$1",
      "^@presentation/(.*)$": "<rootDir>/src/presentation/$1",
      "^@domain/(.*)$": "<rootDir>/src/domain/$1",
      "^@data/(.*)$": "<rootDir>/src/data/$1",
      "^@di/(.*)$": "<rootDir>/src/di/$1"
    }
  }
}
